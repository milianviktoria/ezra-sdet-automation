# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Staging hub base URL (override for other environments)
BASE_URL=https://staging-hub.ezra.com

# Staging API base URL (used by IDOR privacy tests)
API_BASE=https://stage-api.ezra.com

# Test account credentials
EZRA_EMAIL=your_test_email@example.com
EZRA_PASSWORD=your_password

# Staging member GUIDs used in IDOR privacy tests
MEMBER_A_GUID=your-member-a-guid
MEMBER_B_GUID=your-member-b-guid
